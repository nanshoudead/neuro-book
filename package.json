{
  "name": "neuro-book",
  "version": "0.8.11-canary.20260719.161808Z.afed53ec",
  "description": "A local AI workspace for long-form novel writing, integrating a file-based workspace, Markdown Studio, story structure management, and multi-agent writing workflows.",
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "https://github.com/notnotype/neuro-book.git"
  },
  "workspaces": [
    "packages/*"
  ],
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nuxt prepare && bun run generate && bun scripts/build/prepare-system-assets.ts --sync-user-assets --force-sync-user-assets && nuxt dev",
    "dev:warmup": "bun scripts/cli/warmup-dev-server.mjs",
    "nuxt:build": "nuxt prepare && bun run generate && bun scripts/build/prepare-system-assets.ts && nuxt build && bun scripts/build/patch-nitro-runtime-deps.mjs",
    "nuxt:preview": "nuxt preview",
    "analysis": "nuxt analyze --dotenv .env",
    "nuxt:prepare": "nuxt prepare",
    "build": "nuxt prepare && bun run generate && bun scripts/build/prepare-system-assets.ts && tsc",
    "system-assets:prepare": "bun scripts/build/prepare-system-assets.ts",
    "system-assets:typegen": "bun scripts/build/generate-profile-variable-types.ts",
    "profile:metadata": "bun scripts/build/prepare-system-assets.ts",
    "typecheck": "nuxt typecheck --dotenv .env.typecheck --logLevel silent",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:agent": "vitest run server/agent shared/dto",
    "test:agent-state-root": "nuxt prepare && vitest run server/workspace-files/workspace-root-ref.test.ts server/agent/harness/agent-workspace-state-root.test.ts",
    "test:install": "bun run nuxt:prepare && vitest run scripts/install/install.test.ts",
    "migrate": "bun scripts/db/prisma-migrate.mjs",
    "migrate:deploy": "bun scripts/db/prisma-migrate.mjs --deploy",
    "migrate:agent-attachments": "bun scripts/db/migrate-agent-attachments.ts",
    "migrate:agent-session-initial": "bun scripts/db/migrate-agent-session-initial.ts",
    "migrate:agent-session-models": "bun scripts/maintenance/migrate-session-model-refs.ts",
    "migrate:writer-session-initial": "bun scripts/db/migrate-writer-session-initial.ts",
    "generate": "bun scripts/db/prisma-generate.mjs",
    "generate:openapi": "bun scripts/build/generate-openapi-meta.ts",
    "sync:nb-history": "bun scripts/cli/sync-nb-history.ts",
    "config:migrate": "bun scripts/db/migrate-config-system.ts",
    "docker:publish": "bun scripts/deploy/publish-ghcr-image.mjs",
    "package:windows-portable": "bun scripts/deploy/windows-portable-manager.ts --source-archive dist/neuro-book-source.zip --product-archive dist/neuro-book-product-windows-x64.zip",
    "release:source": "bun scripts/release/release-assets.ts source --output dist/neuro-book-source.zip",
    "release:product:windows": "bun scripts/release/release-assets.ts product --platform windows-x64 --output dist/neuro-book-product-windows-x64.zip",
    "release:product:linux": "bun scripts/release/release-assets.ts product --platform linux-x64-glibc --output dist/neuro-book-product-linux-x64-glibc.tar.gz",
    "release:product:linux-aarch64": "bun scripts/release/release-assets.ts product --platform linux-aarch64-glibc --output dist/neuro-book-product-linux-aarch64-glibc.tar.gz",
    "release:product:darwin": "bun scripts/release/release-assets.ts product --platform darwin-x64 --output dist/neuro-book-product-darwin-x64.tar.gz",
    "release:product:darwin-aarch64": "bun scripts/release/release-assets.ts product --platform darwin-aarch64 --output dist/neuro-book-product-darwin-aarch64.tar.gz",
    "product:stage": "bun scripts/deploy/product-runtime.mjs stage",
    "product:start": "bun scripts/deploy/product-runtime.mjs start",
    "product:create-admin": "bun scripts/deploy/product-runtime.mjs create-admin",
    "product:browser-smoke": "node --import tsx scripts/deploy/product-browser-smoke.ts",
    "create-admin": "bun scripts/cli/create-admin.ts",
    "auth:create-admin": "bun scripts/cli/create-admin.ts",
    "studio": "bunx prisma studio --config ./prisma.config.ts",
    "release": "bun scripts/release/release.ts",
    "manager:release": "bun scripts/release/manager-release.ts",
    "runtime:typecheck": "tsc --noEmit -p server/runtime/tsconfig.json",
    "manager:build": "bun run --cwd packages/neuro-book-manager build",
    "manager:test": "bun run --cwd packages/neuro-book-manager test",
    "manager:typecheck": "bun run --cwd packages/neuro-book-manager typecheck",
    "manager:pack": "bun run --cwd packages/neuro-book-manager pack:check",
    "manager:verify-public": "bun scripts/release/verify-public-manager.ts",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "dependencies": {
    "@clack/prompts": "^1.0.0",
    "@dnd-kit/helpers": "^0.3.2",
    "@dnd-kit/vue": "^0.3.2",
    "@earendil-works/pi-agent-core": "0.80.6",
    "@earendil-works/pi-ai": "0.80.6",
    "@iconify-json/lucide": "^1.2.95",
    "@libsql/client": "^0.17.3",
    "@libsql/isomorphic-ws": "^0.1.5",
    "@milkdown/plugin-clipboard": "^7.19.0",
    "@milkdown/plugin-history": "^7.19.0",
    "@milkdown/plugin-prism": "^7.19.0",
    "@milkdown/plugin-slash": "^7.19.0",
    "@milkdown/plugin-tooltip": "^7.19.0",
    "@milkdown/preset-commonmark": "^7.19.0",
    "@milkdown/vue": "^7.19.0",
    "@mozilla/readability": "^0.6.0",
    "@nestjs/common": "^11.1.12",
    "@nestjs/core": "^11.1.12",
    "@nestjs/platform-express": "^11.1.12",
    "@nestjs/swagger": "^11.2.5",
    "@nuxt/kit": "^4.3.1",
    "@nuxtjs/i18n": "^10.4.0",
    "@pinia/nuxt": "^0.11.3",
    "@prisma/adapter-libsql": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@prosemirror-adapter/vue": "^0.4.6",
    "@tiptap/core": "^3.23.1",
    "@tiptap/extension-image": "^3.23.1",
    "@tiptap/extension-placeholder": "^3.23.1",
    "@tiptap/extension-table": "^3.23.1",
    "@tiptap/markdown": "^3.23.1",
    "@tiptap/pm": "^3.23.1",
    "@tiptap/starter-kit": "^3.23.1",
    "@tiptap/suggestion": "^3.23.1",
    "@tiptap/vue-3": "^3.23.1",
    "@types/express": "^5.0.6",
    "@types/global-agent": "^3.0.0",
    "@types/jsoneditor": "^9.9.6",
    "@types/ws": "^8.18.1",
    "@types/yaml-front-matter": "^4.1.3",
    "@unocss/nuxt": "^66.6.2",
    "@vue-flow/background": "^1.3.2",
    "@vue-flow/controls": "^1.1.3",
    "@vue-flow/core": "^1.48.2",
    "@vue-flow/minimap": "^1.5.4",
    "chalk": "^5.6.2",
    "chokidar": "^5.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "colord": "^2.9.3",
    "commander": "^14.0.2",
    "consola": "^3.4.2",
    "croner": "^10.0.1",
    "dayjs": "^1.11.19",
    "diff": "^8.0.3",
    "dompurify": "^3.3.3",
    "dotenv": "^17.2.3",
    "esbuild": "^0.27.2",
    "express": "^5.2.1",
    "fflate": "^0.8.3",
    "fuse.js": "^7.3.0",
    "global-agent": "^3.0.0",
    "h3": "^1.15.5",
    "i": "^0.3.7",
    "jsdom": "^29.1.1",
    "json-editor-vue": "^0.18.1",
    "marked": "^17.0.3",
    "monaco-editor": "^0.55.1",
    "nuxt": "^4.3.1",
    "nuxt-auth-utils": "^0.5.29",
    "partial-json": "^0.1.7",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "pinyin-pro": "^3.28.1",
    "prisma": "^7.8.0",
    "proper-lockfile": "4.1.2",
    "raw-body": "^4.0.0",
    "redis": "^5.10.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "sqlite-vec": "^0.1.9",
    "superjson": "^2.2.6",
    "swagger-ui-express": "^5.0.1",
    "the-new-css-reset": "^1.11.3",
    "tsyringe": "^4.10.0",
    "turndown": "^7.2.4",
    "turndown-plugin-gfm": "^1.0.2",
    "typebox": "^1.1.38",
    "undici": "^7.19.2",
    "unocss": "^66.6.2",
    "vue3-colorpicker": "^2.3.0",
    "ws": "^8.19.0",
    "yaml": "^2.8.2",
    "yaml-front-matter": "^4.1.1",
    "yazl": "^3.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@milkdown/core": "^7.19.0",
    "@milkdown/ctx": "^7.19.0",
    "@milkdown/prose": "^7.19.0",
    "@milkdown/theme-nord": "^7.19.0",
    "@milkdown/transformer": "^7.19.0",
    "@nuxtjs/color-mode": "^4.0.0",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.2",
    "@vueuse/nuxt": "^14.2.1",
    "playwright-core": "^1.61.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitepress": "^2.0.0-alpha.17",
    "vitest": "^4.1.2",
    "vue-tsc": "^3.3.7"
  },
  "private": true
}
