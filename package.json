{
  "name": "neuro-book",
  "version": "0.1.0",
  "description": "面向长篇小说创作的本地 AI 工作台，集成文件化 workspace、Markdown Studio、剧情结构管理和多 Agent 写作流程。",
  "license": "PolyForm-Noncommercial-1.0.0",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "neuro-book-deploy": "./scripts/deploy/neuro-book-deploy.mjs"
  },
  "files": [
    "scripts/deploy/*.mjs",
    "scripts/utils/*.mjs"
  ],
  "scripts": {
    "dev": "bun scripts/build/prepare-system-assets.ts --sync-user-assets && nuxt dev",
    "dev:warmup": "node scripts/cli/warmup-dev-server.mjs",
    "nuxt:build": "bun scripts/build/prepare-system-assets.ts && nuxt build && node scripts/build/patch-nitro-runtime-deps.mjs",
    "nuxt:preview": "nuxt preview",
    "analysis": "nuxt analyze --dotenv .env",
    "nuxt:prepare": "nuxt prepare",
    "build": "bun scripts/build/prepare-system-assets.ts && tsc",
    "system-assets:prepare": "bun scripts/build/prepare-system-assets.ts",
    "system-assets:typegen": "bun scripts/build/generate-profile-variable-types.ts",
    "profile:metadata": "bun scripts/build/prepare-system-assets.ts",
    "typecheck": "nuxt typecheck --dotenv .env.typecheck --logLevel silent",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:agent": "vitest run server/agent shared/dto",
    "migrate": "node scripts/db/prisma-migrate.mjs",
    "migrate:deploy": "node scripts/db/prisma-migrate.mjs --deploy",
    "generate": "node scripts/db/prisma-generate.mjs",
    "generate:openapi": "bun scripts/build/generate-openapi-meta.ts",
    "config:migrate": "bun scripts/db/migrate-config-system.ts",
    "docker:publish": "node scripts/deploy/publish-ghcr-image.mjs",
    "package:windows-portable": "node scripts/deploy/windows-portable.mjs",
    "product:stage": "node scripts/deploy/product-runtime.mjs stage",
    "product:start": "node scripts/deploy/product-runtime.mjs start",
    "product:create-admin": "node scripts/deploy/product-runtime.mjs create-admin",
    "auth:create-admin": "bun scripts/cli/create-admin.ts",
    "studio": "npx prisma studio --config ./prisma.config.ts",
    "deploy": "bun scripts/deploy/deploy.mjs",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "dependencies": {
    "@clack/prompts": "^1.0.0",
    "@dnd-kit/helpers": "^0.3.2",
    "@dnd-kit/vue": "^0.3.2",
    "@earendil-works/pi-agent-core": "^0.75.4",
    "@earendil-works/pi-ai": "^0.75.4",
    "@iconify-json/lucide": "^1.2.95",
    "@libsql/client": "^0.17.3",
    "@libsql/isomorphic-ws": "^0.1.5",
    "@milkdown/plugin-clipboard": "^7.19.0",
    "@milkdown/plugin-history": "^7.19.0",
    "@milkdown/plugin-prism": "^7.19.0",
    "@milkdown/plugin-slash": "^7.19.0",
    "@milkdown/plugin-tooltip": "^7.19.0",
    "@milkdown/preset-commonmark": "^7.19.0",
    "@milkdown/vue": "^7.19.0",
    "@mozilla/readability": "^0.6.0",
    "@nestjs/common": "^11.1.12",
    "@nestjs/core": "^11.1.12",
    "@nestjs/platform-express": "^11.1.12",
    "@nestjs/swagger": "^11.2.5",
    "@nuxt/kit": "^4.3.1",
    "@pinia/nuxt": "^0.11.3",
    "@prisma/adapter-libsql": "7.3.0",
    "@prisma/client": "^7.3.0",
    "@prosemirror-adapter/vue": "^0.4.6",
    "@tiptap/core": "^3.23.1",
    "@tiptap/extension-image": "^3.23.1",
    "@tiptap/extension-placeholder": "^3.23.1",
    "@tiptap/extension-table": "^3.23.1",
    "@tiptap/markdown": "^3.23.1",
    "@tiptap/pm": "^3.23.1",
    "@tiptap/starter-kit": "^3.23.1",
    "@tiptap/suggestion": "^3.23.1",
    "@tiptap/vue-3": "^3.23.1",
    "@types/express": "^5.0.6",
    "@types/global-agent": "^3.0.0",
    "@types/jsoneditor": "^9.9.6",
    "@types/ws": "^8.18.1",
    "@types/yaml-front-matter": "^4.1.3",
    "@unocss/nuxt": "^66.6.2",
    "@vue-flow/background": "^1.3.2",
    "@vue-flow/controls": "^1.1.3",
    "@vue-flow/core": "^1.48.2",
    "@vue-flow/minimap": "^1.5.4",
    "chalk": "^5.6.2",
    "chokidar": "^5.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "commander": "^14.0.2",
    "consola": "^3.4.2",
    "croner": "^10.0.1",
    "dayjs": "^1.11.19",
    "diff": "^8.0.3",
    "dompurify": "^3.3.3",
    "dotenv": "^17.2.3",
    "esbuild": "^0.27.2",
    "express": "^5.2.1",
    "fflate": "^0.8.3",
    "fuse.js": "^7.3.0",
    "global-agent": "^3.0.0",
    "i": "^0.3.7",
    "jsdom": "^29.1.1",
    "json-editor-vue": "^0.18.1",
    "marked": "^17.0.3",
    "monaco-editor": "^0.55.1",
    "nuxt": "^4.3.1",
    "nuxt-auth-utils": "^0.5.29",
    "partial-json": "^0.1.7",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "pinyin-pro": "^3.28.1",
    "prisma": "^7.3.0",
    "redis": "^5.10.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "superjson": "^2.2.6",
    "swagger-ui-express": "^5.0.1",
    "the-new-css-reset": "^1.11.3",
    "tsyringe": "^4.10.0",
    "turndown": "^7.2.4",
    "turndown-plugin-gfm": "^1.0.2",
    "typebox": "^1.1.38",
    "undici": "^7.19.2",
    "unocss": "^66.6.2",
    "ws": "^8.19.0",
    "yaml": "^2.8.2",
    "yaml-front-matter": "^4.1.1",
    "yazl": "^3.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@milkdown/core": "^7.19.0",
    "@milkdown/ctx": "^7.19.0",
    "@milkdown/prose": "^7.19.0",
    "@milkdown/theme-nord": "^7.19.0",
    "@milkdown/transformer": "^7.19.0",
    "@nuxtjs/color-mode": "^4.0.0",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.2",
    "@vueuse/nuxt": "^14.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitepress": "^2.0.0-alpha.17",
    "vitest": "^4.1.2"
  },
  "private": true
}
