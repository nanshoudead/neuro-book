{
    "compilerOptions": {
        "target": "ESNext",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "resolveJsonModule": true,
        "strict": true,
        "skipLibCheck": true,
        "types": [
            "node",
            "bun"
        ],
        "baseUrl": ".",
        "paths": {
            "#manager/*": [
                "./src/*"
            ]
        }
    },
    "include": [
        "src/**/*.ts",
        "vitest.config.ts"
    ]
}
