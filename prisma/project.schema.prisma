// Project Workspace SQLite schema. This database lives inside each Project
// Workspace at .nbook/project.sqlite and is portable with the project.
generator client {
  provider = "prisma-client"
  output   = "../server/generated/project-prisma"
}

datasource db {
  provider = "sqlite"
}

enum StoryThreadStatus {
  active
  draft
  paused
  done
  archived
}

enum StorySceneStatus {
  draft
  active
  written
  revised
  archived
}

enum StoryRefTargetKind {
  content
  thread
  scene
}

enum StoryRefVisibility {
  author
  reader
}

model ProjectMetadata {
  key       String   @id
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

model DatabaseLock {
  key       Int      @id
  updatedAt DateTime @default(now()) @updatedAt
}

model Story {
  id        Int           @id @default(autoincrement())
  title     String
  summary   String        @default("")
  note      String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @default(now()) @updatedAt
  phases    StoryPhase[]
  threads   StoryThread[]
  scenes    StoryScene[]
}

model StoryPhase {
  id        Int           @id @default(autoincrement())
  storyId   Int
  sortOrder Int
  name      String
  title     String
  summary   String        @default("")
  note      String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @default(now()) @updatedAt
  story     Story         @relation(fields: [storyId], references: [id], onDelete: Cascade)
  threads   StoryThread[]

  @@unique([storyId, name])
  @@index([storyId, sortOrder])
}

model StoryThread {
  id                Int               @id @default(autoincrement())
  storyId           Int
  storyPhaseId      Int?
  sortOrder         Int
  name              String
  title             String
  isMainThread      Boolean           @default(false)
  status            StoryThreadStatus @default(draft)
  summary           String            @default("")
  tags              String            @default("[]")
  writingTip        String?
  note              String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @default(now()) @updatedAt
  story             Story             @relation(fields: [storyId], references: [id], onDelete: Cascade)
  storyPhase        StoryPhase?       @relation(fields: [storyPhaseId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  scenes            StoryScene[]
  incomingSceneRefs StorySceneRef[]   @relation("StorySceneRefTargetThread")

  @@unique([storyId, name])
  @@index([storyId, storyPhaseId, sortOrder])
  @@index([storyId, isMainThread, status])
}

model StoryScene {
  id                 Int               @id @default(autoincrement())
  storyId            Int
  threadId           Int
  chapterPath        String?
  threadSortOrder    Int
  chapterSortOrder   Int?
  title              String
  status             StorySceneStatus  @default(draft)
  summary            String            @default("")
  purpose            String?
  writingTip         String?
  note               String?
  startInstant       BigInt?
  endInstant         BigInt?
  subjectIdsJson     String            @default("[]")
  locationSubjectId  String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @default(now()) @updatedAt
  story              Story             @relation(fields: [storyId], references: [id], onDelete: Cascade)
  thread             StoryThread       @relation(fields: [threadId], references: [id], onDelete: Cascade)
  refs               StorySceneRef[]   @relation("StorySceneRefs")
  incomingSceneRefs  StorySceneRef[]   @relation("StorySceneRefTargetScene")

  @@unique([threadId, threadSortOrder])
  @@index([threadId, threadSortOrder])
  @@index([chapterPath, chapterSortOrder])
  @@index([storyId, status])
  @@index([startInstant])
}

model StorySceneRef {
  id                   Int                @id @default(autoincrement())
  sceneId              Int
  sortOrder            Int
  relation             String
  rawTarget            String
  targetKind           StoryRefTargetKind
  targetThreadId       Int?
  targetSceneId        Int?
  visibility           StoryRefVisibility @default(author)
  note                 String?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @default(now()) @updatedAt
  scene                StoryScene         @relation("StorySceneRefs", fields: [sceneId], references: [id], onDelete: Cascade)
  targetThread         StoryThread?       @relation("StorySceneRefTargetThread", fields: [targetThreadId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  targetScene          StoryScene?        @relation("StorySceneRefTargetScene", fields: [targetSceneId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([sceneId, sortOrder])
  @@index([targetThreadId])
  @@index([targetSceneId])
}

model WorldSubject {
  id        String          @id
  type      String
  name      String          @default("")
  createdAt DateTime        @default(now())
  patches   WorldPatch[]

  @@index([type])
}

model WorldSlice {
  id        String          @id @default(cuid())
  instant   BigInt          @unique
  title     String          @default("")
  summary   String          @default("")
  kind      String          @default("event")
  createdAt DateTime        @default(now())
  patches   WorldPatch[]

  @@index([instant])
}

model WorldPatch {
  id        String       @id @default(cuid())
  sliceId   String
  subjectId String
  instant   BigInt
  seq       Int          @default(0)
  path      String
  op        String
  value     String?
  summary   String?
  text      String?
  vector    Bytes?
  model     String?
  slice     WorldSlice   @relation(fields: [sliceId], references: [id], onDelete: Cascade)
  subject   WorldSubject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@index([subjectId, instant, seq])
  @@index([subjectId, path, instant])
  @@index([path])
}
