{
    "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
    "productName": "NeuroBook",
    "version": "0.80.0",
    "identifier": "com.notnotype.neurobook",
    "build": {
        "beforeDevCommand": "bun run dev",
        "devUrl": "http://localhost:3000",
        "beforeBuildCommand": "bun run nuxt:build && bun run product:stage && bun scripts/deploy/prepare-tauri-runtime.mjs",
        "frontendDist": "../.output/public"
    },
    "app": {
        "windows": [],
        "security": {
            "csp": null
        }
    },
    "bundle": {
        "active": true,
        "targets": "nsis",
        "windows": {
            "nsis": {
                "installerHooks": "./windows/hooks.nsh"
            }
        },
        "resources": {
            "resources/create-admin.cmd": "create-admin.cmd",
            "resources/product.zip": "product.zip",
            "resources/product-build-id": "product-build-id",
            "resources/runtime/bun/bun.exe": "runtime/bun/bun.exe"
        },
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ]
    }
}
